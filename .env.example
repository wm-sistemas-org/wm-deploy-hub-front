# Copie para .env. No Coolify, use também como variável de build (Vite embute no bundle).
# Inclua o path da API (/api/v1) se o backend usar esse prefixo.
VITE_API_URL=http://localhost:8000/api/v1

# Opcional: abre o painel público de instaladores em / com esta organização (slug da URL pública).
# Outras orgs continuam acessíveis em /outro-slug. Sem isso, / mostra apenas orientação + link para /login.
# VITE_PUBLIC_ORG_SLUG=minha-organizacao
